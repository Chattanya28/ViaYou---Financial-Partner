@using ViaYou.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account - ViaYou";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"]</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    
    <style>
        * { font-family: 'Inter', system-ui, sans-serif; }
        
        body {
            background: #0A0A0F;
            min-height: 100vh;
        }
        
        .card-3d {
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            transform: translateY(0);
        }
        
        .card-3d:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(59, 130, 246, 0.2);
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-8px); }
        }
        .float-animation {
            animation: float 5s ease-in-out infinite;
        }
        
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        
        .input-focus {
            transition: all 0.3s ease;
        }
        .input-focus:focus {
            border-color: #3B82F6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            outline: none;
        }
        
        .btn-3d {
            transition: all 0.2s ease;
            transform: translateY(0);
        }
        .btn-3d:active {
            transform: translateY(2px);
        }
        
        .orb-1 {
            position: fixed;
            top: -20%;
            right: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(139, 92, 246, 0.05) 70%, transparent 100%);
            border-radius: 50%;
            z-index: 0;
        }
        
        .orb-2 {
            position: fixed;
            bottom: -20%;
            left: -10%;
            width: 450px;
            height: 450px;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 70%, transparent 100%);
            border-radius: 50%;
            z-index: 0;
        }
    </style>
</head>
<body class="relative overflow-hidden">
    <div class="orb-1"></div>
    <div class="orb-2"></div>
    
    <div class="relative z-10 min-h-screen flex items-center justify-center p-4">
        <div class="max-w-md w-full animate-fade-up">
            
            <!-- Logo -->
            <div class="text-center mb-8 float-animation">
                <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto shadow-2xl mb-4">
                    <i class="fas fa-chart-line text-white text-2xl"></i>
                </div>
                <h1 class="text-3xl font-bold text-white">ViaYou</h1>
                <p class="text-gray-500 mt-2 text-sm">Start your financial journey</p>
            </div>
            
            <!-- Register Card -->
            <div class="bg-dark-card rounded-3xl shadow-2xl p-8 card-3d border border-dark-border">
                <h2 class="text-2xl font-bold text-white mb-2">Create Account</h2>
                <p class="text-gray-500 text-sm mb-6">Join ViaYou today</p>
                
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4"></div>
                    
                    <!-- Full Name -->
                    <div class="mb-4">
                        <label asp-for="FullName" class="block text-gray-300 text-sm font-medium mb-2">Full Name</label>
                        <div class="relative">
                            <i class="fas fa-user absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input asp-for="FullName" class="w-full pl-11 pr-4 py-3 bg-dark/50 border border-dark-border rounded-xl text-white placeholder-gray-500 input-focus"
                                   placeholder="John Doe">
                        </div>
                        <span asp-validation-for="FullName" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    
                    <!-- Email -->
                    <div class="mb-4">
                        <label asp-for="Email" class="block text-gray-300 text-sm font-medium mb-2">Email Address</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input asp-for="Email" class="w-full pl-11 pr-4 py-3 bg-dark/50 border border-dark-border rounded-xl text-white placeholder-gray-500 input-focus"
                                   placeholder="you@example.com">
                        </div>
                        <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    
                    <!-- Password -->
                    <div class="mb-4">
                        <label asp-for="Password" class="block text-gray-300 text-sm font-medium mb-2">Password</label>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input asp-for="Password" type="password" class="w-full pl-11 pr-4 py-3 bg-dark/50 border border-dark-border rounded-xl text-white placeholder-gray-500 input-focus"
                                   placeholder="••••••••">
                        </div>
                        <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                        <p class="text-gray-500 text-xs mt-1">At least 6 characters with uppercase and number</p>
                    </div>
                    
                    <!-- Confirm Password -->
                    <div class="mb-6">
                        <label asp-for="ConfirmPassword" class="block text-gray-300 text-sm font-medium mb-2">Confirm Password</label>
                        <div class="relative">
                            <i class="fas fa-check-circle absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input asp-for="ConfirmPassword" type="password" class="w-full pl-11 pr-4 py-3 bg-dark/50 border border-dark-border rounded-xl text-white placeholder-gray-500 input-focus"
                                   placeholder="••••••••">
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                    
                    <!-- Submit Button -->
                    <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-semibold py-3 rounded-xl transition-all shadow-lg btn-3d">
                        <i class="fas fa-user-plus mr-2"></i>
                        Create Account
                    </button>
                </form>
                
                <!-- Login Link -->
                <div class="mt-6 text-center">
                    <p class="text-gray-500 text-sm">
                        Already have an account? 
                        <a asp-action="Login" class="text-blue-500 hover:text-blue-400 font-semibold transition">Sign In</a>
                    </p>
                </div>
            </div>
            
            <div class="mt-6 text-center text-gray-600 text-xs">
                <p>🔒 Secure • 💰 Smart • 🚀 Fast</p>
            </div>
        </div>
    </div>
</body>
</html>