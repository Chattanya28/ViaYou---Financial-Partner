@model List<ViaYou.Core.Entities.Transaction>
@{
    ViewData["Title"] = "Global Ledger";
    var accounts = ViewBag.Accounts as List<ViaYou.Core.Entities.Account> ?? new List<ViaYou.Core.Entities.Account>();
}

<div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl slide-in relative py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
                <i class="fas fa-list-ul text-blue-500"></i>
                Global Ledger
            </h1>
            <p class="text-gray-400 mt-2 text-sm">Deep-search historical transactions, attach metadata, and extract financial reports.</p>
        </div>
        <div class="flex gap-3 w-full md:w-auto">
            <button onclick="exportTableToCSV('transactions.csv')" class="flex-1 md:flex-none px-4 py-2 border border-dark-border text-gray-300 hover:bg-white/5 hover:text-white rounded-xl transition-all text-sm font-medium flex items-center justify-center gap-2">
                <i class="fas fa-file-csv text-emerald-500"></i> Export CSV
            </button>
            <button onclick="exportPDF()" class="flex-1 md:flex-none px-4 py-2 border border-dark-border text-gray-300 hover:bg-white/5 hover:text-white rounded-xl transition-all text-sm font-medium flex items-center justify-center gap-2">
                <i class="fas fa-file-pdf text-rose-500"></i> Export PDF
            </button>
            <button onclick="openAddTransactionModal()" class="flex-1 md:flex-none px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-[0_0_15px_rgba(59,130,246,0.3)] btn-3d flex items-center justify-center gap-2">
                <i class="fas fa-plus"></i> Add Log
            </button>
        </div>
    </div>

    <!-- Master Filter Control Panel -->
    <div class="bg-dark-card border border-dark-border rounded-3xl p-6 shadow-3d card-3d mb-8 relative z-20">
        <form method="get" asp-action="Index" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4 items-end">
            <div class="lg:col-span-2">
                <label class="block text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">Search Pattern</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-500"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" placeholder="Merchant or Amount..." class="w-full pl-9 pr-4 py-2.5 bg-dark border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition text-sm">
                </div>
            </div>

            <div class="lg:col-span-1">
                <label class="block text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">Direction</label>
                <select name="type" class="w-full px-4 py-2.5 bg-dark border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition appearance-none cursor-pointer text-sm">
                    <option value="">Any Type</option>
                    @if(ViewBag.TypeFilter == "Credit"){ <option value="Credit" selected>Credit</option> } else { <option value="Credit">Credit</option> }
                    @if(ViewBag.TypeFilter == "Debit"){ <option value="Debit" selected>Debit</option> } else { <option value="Debit">Debit</option> }
                </select>
            </div>

            <div class="lg:col-span-1">
                <label class="block text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">Category</label>
                <select name="category" class="w-full px-4 py-2.5 bg-dark border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition appearance-none cursor-pointer text-sm">
                    <option value="">All Blocks</option>
                    @{
                        var cats = new List<string> { "Food", "Shopping", "Transport", "Bills", "Health", "Investment", "Salary", "Other" };
                        foreach(var cat in cats)
                        {
                            if (ViewBag.CategoryFilter == cat)
                            { <option value="@cat" selected>@cat</option> }
                            else
                            { <option value="@cat">@cat</option> }
                        }
                    }
                </select>
            </div>

            <div class="lg:col-span-1">
                <label class="block text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">Start Date</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="w-full px-3 py-2.5 bg-dark border border-dark-border rounded-xl text-gray-300 focus:border-blue-500 focus:outline-none transition text-sm">
            </div>

            <div class="lg:col-span-1 flex gap-3">
                <div class="flex-1">
                    <label class="block text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">End Date</label>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="w-full px-3 py-2.5 bg-dark border border-dark-border rounded-xl text-gray-300 focus:border-blue-500 focus:outline-none transition text-sm">
                </div>
            </div>

            <div class="lg:col-span-6 flex justify-end gap-3 mt-2 border-t border-dark-border pt-4">
                <a href="/Transactions" class="px-5 py-2.5 bg-dark border border-dark-border text-gray-400 hover:text-white rounded-xl text-sm font-medium transition cursor-pointer">Clear Matrix</a>
                <button type="submit" class="px-6 py-2.5 bg-blue-600/20 text-blue-400 hover:bg-blue-600 hover:text-white border border-blue-500/30 rounded-xl text-sm font-bold transition">Apply Query Filters</button>
            </div>
        </form>
    </div>

    <!-- Active Analytics & Grid View -->
    <div class="grid lg:grid-cols-4 gap-8">
        
        <!-- Live Filtered Analytics -->
        <div class="lg:col-span-1 space-y-8">
            <div class="bg-dark-card border border-dark-border rounded-3xl p-6 shadow-3d card-3d">
                <h3 class="text-white font-bold mb-6 pb-4 border-b border-dark-border tracking-wide text-sm flex gap-3"><i class="fas fa-chart-pie text-blue-500"></i> Category Spread (Filtered)</h3>
                <div class="relative h-48 w-full flex justify-center items-center">
                    @if (((List<decimal>)ViewBag.CategoriesData).Count == 0 || ViewBag.TypeFilter == "Credit")
                    {
                        <div class="text-center text-gray-500">
                            <i class="fas fa-ghost text-3xl mb-3 opacity-20"></i>
                            <p class="text-xs">No active debit distribution in query.</p>
                        </div>
                    }
                    else
                    {
                        <canvas id="filterCategoryChart"></canvas>
                    }
                </div>
            </div>
            
            <div class="bg-gradient-to-br from-indigo-900/40 to-blue-900/20 border border-blue-500/20 rounded-3xl p-6 shadow-3d card-3d">
                <h3 class="text-blue-400 font-bold mb-2 text-sm"><i class="fas fa-calendar-check mr-2"></i> Recurring Status</h3>
                <p class="text-xs text-gray-400 leading-relaxed mb-4">Transactions highlighted with infinite loops <i class="fas fa-infinity text-blue-500 mx-1"></i> are flagged as permanent recurring deductions in your data pipeline.</p>
            </div>
        </div>

        <!-- Master Data Grid -->
        <div class="lg:col-span-3">
            <div class="bg-dark-card border border-dark-border rounded-3xl shadow-3d card-3d overflow-hidden">
                <div class="overflow-x-auto min-h-[500px]">
                    <table class="w-full text-left border-collapse" id="transactionsTable">
                        <thead>
                            <tr class="bg-dark border-b border-dark-border text-gray-400 text-xs uppercase tracking-widest font-semibold">
                                <th class="p-4 px-6">Timestamp / Receipt</th>
                                <th class="p-4">Entity</th>
                                <th class="p-4">Tags</th>
                                <th class="p-4 text-right px-6">Sum Output</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-border text-sm">
                            @if(!Model.Any())
                            {
                                <tr><td colspan="4" class="p-16 text-center text-gray-500"><i class="fas fa-search text-3xl mb-4 opacity-30"></i><p>No matching structures returned for active query constraints.</p></td></tr>
                            }
                            @foreach (var tx in Model)
                            {
                                <tr class="hover:bg-white/5 transition group">
                                    <td class="p-4 px-6 align-middle">
                                        <div class="flex flex-col">
                                            <span class="text-white font-medium">@tx.Date.ToString("MMM dd, yyyy")</span>
                                            <span class="text-xs text-gray-500">@tx.Date.ToString("hh:mm tt")</span>
                                        </div>
                                        <div class="mt-2 text-xs">
                                            @if (!string.IsNullOrEmpty(tx.ReceiptImage))
                                            {
                                                <a href="@tx.ReceiptImage" target="_blank" class="text-blue-400 hover:text-blue-300 flex items-center gap-1 group-hover:underline">
                                                    <i class="fas fa-file-invoice"></i> View Receipt
                                                </a>
                                            }
                                            else
                                            {
                                                <form asp-action="UploadReceipt" method="post" enctype="multipart/form-data" class="flex items-center gap-2">
                                                    <input type="hidden" name="transactionId" value="@tx.Id" />
                                                    <label class="cursor-pointer text-gray-500 hover:text-white transition flex items-center gap-1">
                                                        <i class="fas fa-paperclip"></i> <span class="hidden group-hover:inline opacity-0 group-hover:opacity-100 transition-opacity">Attach Log</span>
                                                        <input type="file" name="receiptFile" accept="image/*" class="hidden" onchange="this.form.submit()">
                                                    </label>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                    
                                    <td class="p-4 align-middle">
                                        <div class="flex items-center gap-2">
                                            <span class="text-white font-bold text-base truncate max-w-[150px] md:max-w-xs">@tx.Merchant</span>
                                            @if (tx.IsRecurring)
                                            {
                                                <span class="text-xs text-blue-500" title="Recurring Payment"><i class="fas fa-infinity"></i></span>
                                            }
                                        </div>
                                        <div class="flex gap-2 text-xs text-gray-500 mt-0.5">
                                            <i class="fas fa-building-columns relative top-0.5"></i> @tx.Account?.BankName (..@(tx.Account?.AccountNumber != null ? tx.Account.AccountNumber.Substring(Math.Max(0, tx.Account.AccountNumber.Length - 4)) : "****"))
                                        </div>
                                    </td>
                                    
                                    <td class="p-4 align-middle">
                                        <span class="px-3 py-1 bg-dark text-gray-300 rounded-lg text-xs font-semibold tracking-wider border border-white/5">
                                            @tx.Category
                                        </span>
                                    </td>

                                    <td class="p-4 px-6 align-middle text-right">
                                        @if (tx.Type == "Credit")
                                        {
                                            <span class="text-emerald-500 font-bold bg-emerald-500/10 px-3 py-1.5 rounded-lg border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]">+₹@tx.Amount.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-white font-bold tracking-wider">-₹@tx.Amount.ToString("N0")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Transaction Global Modal -->
<div id="addTransactionModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-dark/80 backdrop-blur-sm" onclick="closeAddTransactionModal()"></div>
    
    <div class="relative bg-dark-card border border-dark-border rounded-2xl shadow-2xl p-6 w-full max-w-lg mx-4 transform scale-95 transition-transform duration-300" id="addTransactionModalContent">
        <div class="flex justify-between items-center mb-6 pb-4 border-b border-dark-border">
            <h3 class="text-xl font-bold text-white flex items-center gap-3"><i class="fas fa-bolt text-amber-500"></i> Manual Override Insertion</h3>
            <button onclick="closeAddTransactionModal()" class="text-gray-500 hover:text-white transition cursor-pointer"><i class="fas fa-times text-xl"></i></button>
        </div>
        
        <form asp-controller="Transactions" asp-action="AddTransaction" method="post">
            <div class="space-y-4">
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Flow Direction</label>
                        <select name="type" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition cursor-pointer font-bold">
                            <option value="Debit">Debit (Outgoing)</option>
                            <option value="Credit">Credit (Incoming)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Amount (₹)</label>
                        <input type="number" name="amount" step="0.01" min="0.01" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-white font-bold text-lg focus:border-blue-500 focus:outline-none transition text-right shadow-inner" placeholder="0.00" />
                    </div>
                </div>

                <div>
                    <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Target Entity (Merchant)</label>
                    <input type="text" name="merchant" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition" placeholder="e.g. Amazon, Payroll" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Time Vector</label>
                        <input type="date" name="Date" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-gray-300 focus:border-blue-500 focus:outline-none transition" />
                    </div>
                    <div>
                        <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Category Link</label>
                        <select name="Category" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition cursor-pointer">
                            <option value="Food">Food & Dining</option>
                            <option value="Shopping">Shopping & Retail</option>
                            <option value="Transport">Transportation</option>
                            <option value="Bills">Bills & Utilities</option>
                            <option value="Health">Health & Fitness</option>
                            <option value="Investment">Investments</option>
                            <option value="Salary">Salary/Income</option>
                            <option value="Other">Other Protocol</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-gray-400 text-xs font-semibold mb-1 uppercase tracking-wide">Funding Source Matrix</label>
                    <select name="accountId" required class="w-full px-4 py-2.5 bg-dark/50 border border-dark-border rounded-xl text-white focus:border-blue-500 focus:outline-none transition cursor-pointer">
                        <option value="">-- Connect Account --</option>
                        @foreach (var acc in accounts)
                        {
                            <option value="@acc.Id">@acc.BankName (Bal: ₹@acc.Balance.ToString("N0"))</option>
                        }
                    </select>
                </div>
                
                <div class="mt-4 pt-4 border-t border-dark-border">
                    <label class="flex items-center cursor-pointer group w-max">
                        <div class="relative">
                            <input type="checkbox" name="isRecurring" value="true" class="sr-only peer">
                            <div class="w-9 h-5 bg-dark border border-dark-border rounded-full peer peer-checked:bg-blue-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-300 peer-checked:after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all shadow-inner"></div>
                        </div>
                        <span class="ml-3 text-sm font-medium text-blue-400 tracking-wide group-hover:text-blue-300 transition-colors"><i class="fas fa-infinity text-xs mr-1"></i> Tag as Recurring Loop</span>
                    </label>
                </div>
                
                <!-- Anti-forgery for checkbox specifically sending false if unchecked not required by primitive MVC, but natively we only send value="true" if checked which binds true defaults to false for bool param -->

            </div>

            <div class="flex space-x-3 mt-8">
                <button type="button" onclick="closeAddTransactionModal()" class="flex-1 px-4 py-3 rounded-xl border border-dark-border text-gray-300 hover:bg-white/5 transition font-bold text-sm btn-3d">
                    Abort Execution
                </button>
                <button type="submit" class="flex-1 px-4 py-3 rounded-xl bg-gradient-to-r from-amber-600 to-amber-500 hover:from-amber-500 hover:to-amber-400 text-white font-bold text-sm shadow-xl shadow-amber-500/20 transition btn-3d">
                    Inject Sequence
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Export Logic Block (Native Frontend DOM Scraper)
        function exportTableToCSV(filename) {
            var csv = [];
            var rows = document.querySelectorAll("#transactionsTable tr");
            
            for (var i = 0; i < rows.length; i++) {
                var row = [], cols = rows[i].querySelectorAll("td, th");
                
                // Exclude empty tables
                if(rows[i].innerText.includes("No matching structures")) return alert("Data grid is empty. Nothing to export.");

                for (var j = 0; j < cols.length; j++) 
                    row.push('"' + cols[j].innerText.replace(/"/g, '""').replace(/\n/g, " ") + '"');
                
                csv.push(row.join(","));        
            }

            // Download Link
            var csvFile = new Blob([csv.join("\n")], {type: "text/csv"});
            var downloadLink = document.createElement("a");
            downloadLink.download = filename;
            downloadLink.href = window.URL.createObjectURL(csvFile);
            downloadLink.style.display = "none";
            document.body.appendChild(downloadLink);
            downloadLink.click();
        }

        // PDF Print Dialog
        function exportPDF() {
            window.print();
        }

        // Add Transaction Modal Hooks
        function openAddTransactionModal() {
            const modal = document.getElementById('addTransactionModal');
            const content = document.getElementById('addTransactionModalContent');
            modal.classList.remove('hidden');
            requestAnimationFrame(() => {
                modal.classList.remove('opacity-0');
                modal.classList.add('opacity-100');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            });
        }

        function closeAddTransactionModal() {
            const modal = document.getElementById('addTransactionModal');
            const content = document.getElementById('addTransactionModalContent');
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        // Live Category Chart
        const pieLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CategoriesLabels ?? new List<string>()));
        const pieData =   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CategoriesData ?? new List<decimal>()));

        const categoryCtx = document.getElementById('filterCategoryChart')?.getContext('2d');
        if (categoryCtx && pieData.length > 0) {
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: pieLabels,
                    datasets: [{
                        data: pieData,
                        backgroundColor: [
                            'rgba(59, 130, 246, 0.8)',  
                            'rgba(139, 92, 246, 0.8)',  
                            'rgba(236, 72, 153, 0.8)',  
                            'rgba(245, 158, 11, 0.8)',  
                            'rgba(16, 185, 129, 0.8)',  
                            'rgba(99, 102, 241, 0.8)'   
                        ],
                        borderWidth: 2,
                        borderColor: '#1e1e2a' 
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#111115', borderColor: '#333340', borderWidth: 1 }
                    }
                }
            });
        }
    </script>
}
