@{
    ViewData["Title"] = "Analytics Engine";
}

<div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl slide-in relative py-8">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
                <i class="fas fa-chart-line text-emerald-500"></i>
                Financial Analytics
            </h1>
            <p class="text-gray-400 mt-2 text-sm">Real-time data telemetry generating actionable insights.</p>
        </div>
    </div>

    <!-- Telemetry Strip -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-dark-card rounded-2xl shadow-3d border border-dark-border p-6 card-3d">
            <p class="text-gray-400 text-sm font-semibold mb-2">Income (This Month)</p>
            <h2 class="text-3xl font-bold text-emerald-500">₹@Convert.ToDecimal(ViewBag.MonthlyIncome ?? 0).ToString("N0")</h2>
            <div class="mt-4 flex items-center text-xs text-emerald-400 gap-1 opacity-75">
                <i class="fas fa-arrow-trend-up"></i>
                <span>Active Core Cashflow</span>
            </div>
        </div>

        <div class="bg-dark-card rounded-2xl shadow-3d border border-dark-border p-6 card-3d">
            <p class="text-gray-400 text-sm font-semibold mb-2">Expenses (This Month)</p>
            <h2 class="text-3xl font-bold text-rose-500">₹@Convert.ToDecimal(ViewBag.MonthlyExpense ?? 0).ToString("N0")</h2>
            <div class="mt-4 flex items-center text-xs text-rose-400 gap-1 opacity-75">
                <i class="fas fa-arrow-trend-down"></i>
                <span>Aggregate Outgoing</span>
            </div>
        </div>

        <div class="bg-dark-card rounded-2xl shadow-3d border border-dark-border p-6 card-3d relative overflow-hidden">
            <div class="absolute -right-6 -top-6 text-blue-500/10"><i class="fas fa-wallet text-9xl"></i></div>
            <p class="text-gray-400 text-sm font-semibold mb-2 relative z-10">Net Cash Yield</p>
            @{
                decimal net = Convert.ToDecimal(ViewBag.NetYield ?? 0);
                string netClass = net >= 0 ? "text-blue-500" : "text-amber-500";
                string netSign = net >= 0 ? "+" : "";
            }
            <h2 class="text-3xl font-bold @netClass relative z-10">@netSign₹@net.ToString("N0")</h2>
            <div class="mt-4 flex items-center text-xs text-blue-400 gap-1 opacity-75 relative z-10">
                <i class="fas fa-scale-balanced"></i>
                <span>Monthly Efficiency Metric</span>
            </div>
        </div>
    </div>

    <!-- Unified Matrix Graphics -->
    <div class="grid lg:grid-cols-2 gap-8">
        <!-- 6 Month Trend Bar Chart -->
        <div class="bg-dark-card rounded-3xl shadow-3d border border-dark-border p-6 card-3d">
            <h3 class="text-lg font-bold text-white mb-6">Cashflow Trajectory (6 Months)</h3>
            <div class="relative h-72 w-full">
                <canvas id="trendChart"></canvas>
            </div>
        </div>

        <!-- Doughnut Distribution -->
        <div class="bg-dark-card rounded-3xl shadow-3d border border-dark-border p-6 card-3d">
            <h3 class="text-lg font-bold text-white mb-6">Expenditure Distribution</h3>
            <div class="relative h-72 w-full flex justify-center items-center">
                @if (((List<decimal>)ViewBag.PieData).Count == 0)
                {
                    <div class="text-center text-gray-500">
                        <i class="fas fa-chart-pie text-4xl mb-3 opacity-20"></i>
                        <p class="text-sm">No expenditure data points active.</p>
                    </div>
                }
                else
                {
                    <canvas id="categoryChart"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Data Payload Extraction
        const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TrendLabels ?? new List<string>()));
        const trendIncome = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TrendIncome ?? new List<decimal>()));
        const trendExpense = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TrendExpense ?? new List<decimal>()));

        const pieLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PieLabels ?? new List<string>()));
        const pieData =   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PieData ?? new List<decimal>()));

        // Bar Chart Initializer
        const trendCtx = document.getElementById('trendChart')?.getContext('2d');
        if (trendCtx) {
            new Chart(trendCtx, {
                type: 'bar',
                data: {
                    labels: trendLabels,
                    datasets: [
                        {
                            label: 'Income',
                            data: trendIncome,
                            backgroundColor: 'rgba(16, 185, 129, 0.8)', // Emerald
                            borderColor: '#10B981',
                            borderWidth: 1,
                            borderRadius: 6
                        },
                        {
                            label: 'Expense',
                            data: trendExpense,
                            backgroundColor: 'rgba(244, 63, 94, 0.8)', // Rose
                            borderColor: '#F43F5E',
                            borderWidth: 1,
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: '#9CA3AF' } }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { color: '#9CA3AF' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#9CA3AF' }
                        }
                    }
                }
            });
        }

        // Doughnut Initializer
        const categoryCtx = document.getElementById('categoryChart')?.getContext('2d');
        if (categoryCtx && pieData.length > 0) {
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: pieLabels,
                    datasets: [{
                        data: pieData,
                        backgroundColor: [
                            'rgba(59, 130, 246, 0.8)',  // Blue
                            'rgba(139, 92, 246, 0.8)',  // Purple
                            'rgba(236, 72, 153, 0.8)',  // Pink
                            'rgba(245, 158, 11, 0.8)',  // Amber
                            'rgba(16, 185, 129, 0.8)',  // Emerald
                            'rgba(99, 102, 241, 0.8)'   // Indigo
                        ],
                        borderWidth: 2,
                        borderColor: '#111115' // dark-card hex to look like separation cuts
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { 
                            position: 'right',
                            labels: { color: '#9CA3AF', padding: 20 }
                        }
                    }
                }
            });
        }
    </script>
}
