@{
    ViewData["Title"] = "Command Your Wealth - ViaYou";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ViaYou | Command Your Wealth</title>
    <style>
        @@keyframes pulseGlow {
            0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
            70% { box-shadow: 0 0 0 20px rgba(59, 130, 246, 0); }
            100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
        }
        
        @@keyframes floatAnimation {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(1deg); }
        }

        @@keyframes ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        
        .hero-blob {
            animation: pulseGlow 4s infinite, floatAnimation 6s ease-in-out infinite;
        }
        
        .glass-panel {
            background: rgba(30, 30, 42, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.4s ease;
        }
        
        .glass-panel:hover {
            transform: translateY(-8px);
            border-color: rgba(59, 130, 246, 0.3);
            background: rgba(40, 40, 55, 0.8);
            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(59, 130, 246, 0.1);
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .ticker-container {
            width: 100%;
            overflow: hidden;
            background: linear-gradient(90deg, rgba(10,10,15,1) 0%, rgba(30,30,42,0.8) 50%, rgba(10,10,15,1) 100%);
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: relative;
        }

        .ticker-track {
            display: flex;
            width: 200%;
            animation: ticker 40s linear infinite;
        }

        .ticker-track:hover {
            animation-play-state: paused;
        }

        .gradient-step-line {
            background: linear-gradient(180deg, #3B82F6 0%, transparent 100%);
        }
    </style>
</head>
<body class="bg-dark text-white font-sans overflow-x-hidden antialiased selection:bg-blue-500/30 selection:text-white">

    <!-- Hero Section -->
    <div class="relative pt-32 pb-20 lg:pt-48 lg:pb-24 overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-blue-600/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>
        <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-purple-600/20 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>
        
        <div class="container mx-auto px-6 relative z-10 text-center max-w-5xl">
            <div class="inline-flex items-center space-x-2 bg-dark-card border border-dark-border rounded-full px-5 py-2 mb-8 animate-fade-up">
                <i class="fas fa-bolt text-amber-400"></i>
                <span class="text-sm font-medium text-gray-300 tracking-wide">ViaYou Platform 3.0 is Live</span>
            </div>
            
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white tracking-tight mb-8 leading-tight animate-fade-up" style="animation-delay: 0.1s;">
                Take Control of<br />
                <span class="gradient-text">Your Finances.</span>
            </h1>
            
            <p class="text-lg md:text-2xl text-gray-400 mb-10 max-w-3xl mx-auto leading-relaxed animate-fade-up" style="animation-delay: 0.2s;">
                The ultimate neo-banking command center. Aggregate accounts, optimize idle cash with AI algorithms, and simulate financial goals in real-time.
            </p>
            
            <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-6 animate-fade-up" style="animation-delay: 0.3s;">
                <a href="/Auth/Register" class="w-full sm:w-auto px-10 py-5 hero-blob bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-bold rounded-2xl shadow-xl shadow-blue-500/20 transition-all text-xl btn-3d">
                    Get Started Free
                </a>
                <a href="#features" class="w-full sm:w-auto px-10 py-5 bg-dark-card border border-dark-border hover:bg-white/5 text-gray-300 font-bold rounded-2xl transition-all text-xl text-center flex items-center justify-center gap-3">
                    <i class="fas fa-play-circle"></i> See How It Works
                </a>
            </div>
        </div>
    </div>

    <!-- Live FD Rate Ticker -->
    <div class="ticker-container py-4 relative z-20 animate-fade-up" style="animation-delay: 0.4s;">
        <!-- Fade Edges -->
        <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-dark to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-dark to-transparent z-10"></div>
        
        <div class="ticker-track flex items-center space-x-12 px-6">
            <!-- Doubled for Infinite Marquee Effect -->
            @for(int i=0; i<2; i++)
            {
                <div class="flex items-center space-x-3 whitespace-nowrap"><i class="fas fa-fire text-amber-500"></i><span class="font-bold text-white">AU Small Finance</span><span class="text-emerald-400 font-bold">8.0% p.a.</span></div>
                <div class="flex items-center space-x-3 whitespace-nowrap"><i class="fas fa-chart-line text-blue-500"></i><span class="font-bold text-white">Bandhan Bank</span><span class="text-emerald-400 font-bold">7.6% p.a.</span></div>
                <div class="flex items-center space-x-3 whitespace-nowrap"><span class="font-bold text-white">IDFC FIRST Bank</span><span class="text-emerald-400 font-bold">7.5% p.a.</span></div>
                <div class="flex items-center space-x-3 whitespace-nowrap"><span class="font-bold text-white">Equitas Small Finance</span><span class="text-emerald-400 font-bold">8.1% p.a.</span></div>
                <div class="flex items-center space-x-3 whitespace-nowrap"><span class="font-bold text-white">HDFC Bank</span><span class="text-blue-400 font-bold">7.2% p.a.</span></div>
                <div class="flex items-center space-x-3 whitespace-nowrap"><span class="font-bold text-white">ICICI Bank</span><span class="text-blue-400 font-bold">7.1% p.a.</span></div>
            }
        </div>
    </div>

    <!-- 6 Features Grid -->
    <div id="features" class="py-24 bg-dark relative z-10">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="text-center mb-16">
                <span class="text-blue-500 font-bold tracking-widest uppercase text-sm">Platform Arsenal</span>
                <h2 class="text-4xl md:text-5xl font-extrabold text-white mt-3 mb-6">Built for algorithmic wealth.</h2>
                <p class="text-xl text-gray-400 max-w-2xl mx-auto">ViaYou integrates six core fintech pillars to put your entire financial life on intelligent autopilot.</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-blue-500/20">
                        <i class="fas fa-building-columns text-blue-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Universal Aggregation</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">Bridge all your distributed bank accounts into one mathematical dashboard. See your true consolidated net worth update live.</p>
                </div>

                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-emerald-500/20">
                        <i class="fas fa-money-bill-wave text-emerald-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Idle Cash AI</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">Our bots instantly flag 'lazy' cash sitting in 3% savings bases, natively generating 8%+ routing protocols into verified FDs.</p>
                </div>

                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-purple-500/20">
                        <i class="fas fa-bullseye text-purple-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Goals Simulator</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">Stop guessing. Plot cars, homes, or vacations and let our compounding interest engine project your exact completion dates.</p>
                </div>

                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-pink-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-pink-500/20">
                        <i class="fas fa-chart-pie text-pink-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Data Analytics</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">Beautiful Chart.js integrations break down your expenditure categories and map 6-month trajectory flows instantly.</p>
                </div>

                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-amber-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-amber-500/20">
                        <i class="fas fa-file-invoice-dollar text-amber-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Smart Bill Tracker</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">Forward-schedule recurring liabilities. Get warned visually about upcoming due dates, and execute direct internal deductions.</p>
                </div>

                <div class="glass-panel rounded-3xl p-8 card-3d">
                    <div class="w-16 h-16 bg-red-500/10 rounded-2xl flex items-center justify-center mb-6 shadow-inner border border-red-500/20">
                        <i class="fas fa-fingerprint text-red-500 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Military Security</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">End-to-End encryption with a gamified 100-point security hub tracking 2FA vectors, revoked sessions, and password matrices.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- How It Works (4 Steps) -->
    <div class="py-24 relative overflow-hidden bg-dark-card border-t border-b border-dark-border">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="text-center mb-20">
                <span class="text-blue-500 font-bold tracking-widest uppercase text-sm">Onboarding</span>
                <h2 class="text-4xl md:text-5xl font-extrabold text-white mt-3 mb-6">Master your money in 4 steps.</h2>
            </div>

            <div class="grid md:grid-cols-4 gap-8 relative">
                <!-- BG connecting line -->
                <div class="hidden md:block absolute top-8 left-[10%] right-[10%] h-0.5 bg-dark-border z-0"></div>

                <!-- Step 1 -->
                <div class="relative z-10 flex flex-col items-center text-center">
                    <div class="w-16 h-16 rounded-full bg-blue-600 text-white font-bold text-2xl flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(59,130,246,0.5)] border-4 border-dark-card">1</div>
                    <h3 class="text-xl font-bold text-white mb-3">Join ViaYou</h3>
                    <p class="text-gray-400 text-sm">Sign up securely in 60 seconds. No credit card required.</p>
                </div>

                <!-- Step 2 -->
                <div class="relative z-10 flex flex-col items-center text-center mt-12 md:mt-0">
                    <div class="w-16 h-16 rounded-full bg-dark-border text-gray-300 font-bold text-2xl flex items-center justify-center mb-6 border-4 border-dark-card group-hover:bg-blue-600 transition-colors">2</div>
                    <h3 class="text-xl font-bold text-white mb-3">Link Accounts</h3>
                    <p class="text-gray-400 text-sm">Integrate your active bank accounts to construct your net worth baseline.</p>
                </div>

                <!-- Step 3 -->
                <div class="relative z-10 flex flex-col items-center text-center mt-12 md:mt-0">
                    <div class="w-16 h-16 rounded-full bg-dark-border text-gray-300 font-bold text-2xl flex items-center justify-center mb-6 border-4 border-dark-card">3</div>
                    <h3 class="text-xl font-bold text-white mb-3">Define Targets</h3>
                    <p class="text-gray-400 text-sm">Inject your lifetime goals and pending bills into the prediction engine.</p>
                </div>

                <!-- Step 4 -->
                <div class="relative z-10 flex flex-col items-center text-center mt-12 md:mt-0">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-emerald-500 to-green-500 text-white font-bold text-2xl flex items-center justify-center mb-6 border-4 border-dark-card shadow-[0_0_30px_rgba(16,185,129,0.5)]">4</div>
                    <h3 class="text-xl font-bold text-white mb-3">Watch It Compound</h3>
                    <p class="text-gray-400 text-sm">Execute optimization suggestions and achieve financial velocity.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Testimonials -->
    <div class="py-24 bg-dark relative z-10">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="text-center mb-16">
                <span class="text-emerald-500 font-bold tracking-widest uppercase text-sm">Community Validation</span>
                <h2 class="text-4xl md:text-5xl font-extrabold text-white mt-3">Trusted by the obsessed.</h2>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <div class="glass-panel p-8 rounded-3xl relative">
                    <i class="fas fa-quote-left text-blue-500/20 text-6xl absolute top-6 right-6 z-0"></i>
                    <div class="flex text-amber-400 text-sm mb-4 relative z-10">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-300 mb-8 relative z-10 leading-relaxed">"The Idle Cash detection literally found ₹1.5L collecting dust in a generic savings account. I moved it to AU Small Finance the next day."</p>
                    <div class="flex items-center gap-4 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center font-bold text-xl">A</div>
                        <div>
                            <h4 class="text-white font-bold">Arjun Mehta</h4>
                            <p class="text-gray-500 text-xs">Software Engineer</p>
                        </div>
                    </div>
                </div>

                <div class="glass-panel p-8 rounded-3xl relative hidden md:block mt-8">
                    <i class="fas fa-quote-left text-purple-500/20 text-6xl absolute top-6 right-6 z-0"></i>
                    <div class="flex text-amber-400 text-sm mb-4 relative z-10">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-300 mb-8 relative z-10 leading-relaxed">"Goal Simulator is magic. It perfectly calculated that I could afford my down payment 4 months earlier than my spreadsheet estimated."</p>
                    <div class="flex items-center gap-4 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-purple-500/20 text-purple-400 flex items-center justify-center font-bold text-xl">P</div>
                        <div>
                            <h4 class="text-white font-bold">Priya Sharma</h4>
                            <p class="text-gray-500 text-xs">Architect</p>
                        </div>
                    </div>
                </div>

                <div class="glass-panel p-8 rounded-3xl relative">
                    <i class="fas fa-quote-left text-rose-500/20 text-6xl absolute top-6 right-6 z-0"></i>
                    <div class="flex text-amber-400 text-sm mb-4 relative z-10">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                    <p class="text-gray-300 mb-8 relative z-10 leading-relaxed">"The dark mode UI is gorgeous, but the Security Hub gamification is what makes me log in every day just to preserve my 100 rating."</p>
                    <div class="flex items-center gap-4 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-rose-500/20 text-rose-400 flex items-center justify-center font-bold text-xl">R</div>
                        <div>
                            <h4 class="text-white font-bold">Rahul Verma</h4>
                            <p class="text-gray-500 text-xs">Digital Marketer</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Massive CTA Pre-Footer -->
    <div class="py-24 relative overflow-hidden bg-gradient-to-b from-dark to-[#0B0F19]">
        <!-- Big abstract glow -->
        <div class="absolute left-1/2 bottom-0 w-[800px] h-[400px] -translate-x-1/2 translate-y-1/2 bg-blue-600/30 rounded-[100%] blur-[100px]"></div>
        
        <div class="container mx-auto px-6 relative z-10 text-center max-w-4xl">
            <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-8">Stop spectating. Started building.</h2>
            <p class="text-xl text-gray-400 mb-10">Join thousands of Indians leveraging ViaYou to surgically optimize their net worth trajectory.</p>
            <a href="/Auth/Register" class="inline-flex items-center gap-3 px-10 py-5 bg-white text-dark hover:bg-gray-200 font-bold rounded-2xl transition-all text-xl btn-3d">
                Launch Platform Engine <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>

    <!-- Expanded Footer -->
    <footer class="border-t border-dark-border bg-[#05050A] pt-16 pb-8">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
                <!-- Brand Info -->
                <div class="col-span-1 lg:col-span-1">
                    <div class="flex items-center space-x-3 mb-6">
                        <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex justify-center items-center shadow-lg">
                            <span class="text-white font-bold text-xl">V</span>
                        </div>
                        <span class="text-2xl font-bold tracking-tight text-white">ViaYou</span>
                    </div>
                    <p class="text-gray-400 text-sm leading-relaxed mb-6">An advanced financial intelligence platform designed to replace fragmented banking applications with one mathematical truth.</p>
                    <div class="flex gap-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-dark-border flex items-center justify-center text-gray-400 hover:text-white hover:bg-blue-600 transition-colors"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-dark-border flex items-center justify-center text-gray-400 hover:text-white hover:bg-blue-800 transition-colors"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-dark-border flex items-center justify-center text-gray-400 hover:text-white hover:bg-gray-700 transition-colors"><i class="fab fa-github"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-dark-border flex items-center justify-center text-gray-400 hover:text-white hover:bg-pink-600 transition-colors"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>

                <!-- Product Links -->
                <div>
                    <h4 class="text-white font-bold mb-6 tracking-wide">Product Hub</h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors">Dashboard Overview</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors">Goal Simulator</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors">Live FD Comparisons</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors">Tax Algorithms</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-400 transition-colors">Security Center</a></li>
                    </ul>
                </div>

                <!-- Company -->
                <div>
                    <h4 class="text-white font-bold mb-6 tracking-wide">Company</h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="#" class="text-gray-400 hover:text-purple-400 transition-colors">About Us</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-purple-400 transition-colors">Careers</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-purple-400 transition-colors">Contact Support</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-purple-400 transition-colors">Blog</a></li>
                    </ul>
                </div>

                <!-- Legal -->
                <div>
                    <h4 class="text-white font-bold mb-6 tracking-wide">Legal & Privacy</h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Data Encryption</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">RBI Compliance</a></li>
                    </ul>
                </div>
            </div>

            <div class="border-t border-dark-border pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
                <p>&copy; 2026 ViaYou Financial Platform. Designed by Antigravity.</p>
                <div class="flex space-x-6 mt-4 md:mt-0">
                    <span class="flex items-center gap-2"><i class="fas fa-shield-haltered text-gray-600"></i> AES-256 Encrypted</span>
                    <span class="flex items-center gap-2"><i class="fas fa-server text-gray-600"></i> 99.9% Uptime</span>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
