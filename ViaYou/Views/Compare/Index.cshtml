@model List<ViaYou.Core.Entities.BankPolicy>
@{
    ViewData["Title"] = "FD Comparison Engine";
}

<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-white mb-2">Compare FD Rates</h1>
            <p class="text-gray-400">Find the best returns for your idle cash across 15+ banks</p>
        </div>
        <div class="bg-dark-card p-4 rounded-2xl border border-dark-border shadow-lg flex items-center space-x-4">
            <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center">
                <i class="fas fa-coins text-blue-500 text-xl"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 font-medium">Standard Savings Rate</p>
                <div class="text-xl font-bold text-white">3.50% <span class="text-sm text-gray-400 font-normal">p.a.</span></div>
            </div>
        </div>
    </div>

    <!-- Interactive Calculator Section -->
    <div class="bg-gradient-to-br from-dark-card to-dark border border-dark-border rounded-3xl p-6 md:p-8 mb-8 card-3d shadow-xl relative overflow-hidden">
        <!-- Glow effects -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl -mr-32 -mt-32 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl -ml-32 -mb-32 pointer-events-none"></div>
        
        <div class="relative z-10 max-w-3xl mx-auto text-center">
            <h2 class="text-xl font-semibold text-white mb-6">How much would you like to invest?</h2>
            
            <div class="flex justify-center items-center mb-6">
                <span class="text-3xl font-bold text-gray-400 mr-2">₹</span>
                <input type="number" id="amountInput" value="100000" min="1000" max="1000000" step="1000" 
                       class="bg-transparent text-5xl md:text-6xl font-black text-white w-48 md:w-64 text-center focus:outline-none border-b-2 border-dark-border focus:border-blue-500 transition pb-2 appearance-none p-0" />
            </div>
            
            <div class="px-4 md:px-12 mb-8">
                <input type="range" id="amountSlider" min="1000" max="1000000" step="1000" value="100000"
                       class="w-full h-2 bg-dark-border rounded-lg appearance-none cursor-pointer accent-blue-500">
                <div class="flex justify-between text-xs text-gray-500 mt-2 font-medium">
                    <span>₹1,000</span>
                    <span>₹10,00,000</span>
                </div>
            </div>
            
            <div class="bg-blue-500/10 border border-blue-500/20 rounded-2xl p-4 inline-flex items-center space-x-3 float-animation">
                <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm">
                    <i class="fas fa-lightbulb"></i>
                </div>
                <div class="text-left">
                    <p class="text-sm text-blue-200">With the best rate of <span class="font-bold text-white max-rate-display">@Model.First().InterestRate%</span></p>
                    <p class="text-xs text-blue-400">You can earn <span class="font-bold text-white">₹<span id="extraEarnThisYear">...</span></span> more than a standard savings account</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Banks Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6" id="banksGrid">
        @for (int i = 0; i < Model.Count; i++)
        {
            var policy = Model[i];
            var isBest = i == 0;
            var borderClass = isBest ? "border-green-500/50 shadow-[0_0_15px_rgba(34,197,94,0.15)]" : "border-dark-border hover:border-blue-500/30";
            var bgClass = isBest ? "bg-gradient-to-br from-green-900/10 to-dark-card" : "bg-dark-card";
            
            <div id="bank-card-@policy.Id" class="rounded-2xl border @borderClass @bgClass p-6 card-3d relative transition-all duration-300" data-rate="@policy.InterestRate">
                @if (isBest)
                {
                    <div class="absolute -top-3 right-6 bg-gradient-to-r from-green-500 to-emerald-400 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-lg">
                        Best Rate
                    </div>
                }
                
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 rounded-xl bg-dark/50 border border-dark-border flex items-center justify-center">
                            <i class="@policy.LogoUrl text-xl"></i>
                        </div>
                        <div>
                            <h3 class="text-white font-semibold truncate max-w-[150px]" title="@policy.BankName">
                                @policy.BankName
                            </h3>
                            <p class="text-xs text-gray-500">Min. ₹@policy.MinimumAmount.ToString("N0")</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-2xl font-black @(isBest ? "text-green-400" : "text-white")">
                            @policy.InterestRate<span class="text-sm font-normal text-gray-500">%</span>
                        </div>
                        <p class="text-[10px] text-gray-500 uppercase tracking-widest">P.A. (1 Yr)</p>
                    </div>
                </div>
                
                <div class="bg-dark/50 rounded-xl p-4 border border-dark-border mb-4">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-xs text-gray-400">Total Returns (1 Yr)</span>
                        <span class="text-sm font-bold text-white fd-return-amt" data-val="0">₹0</span>
                    </div>
                    <div class="w-full bg-dark-border rounded-full h-1.5 mb-1 overflow-hidden flex">
                        <div class="bg-blue-500 h-1.5 w-[90%] rounded-l-full"></div>
                        <div class="bg-green-500 h-1.5 w-[10%] rounded-r-full flex-grow return-bar transition-all duration-500"></div>
                    </div>
                    <div class="flex justify-between items-center mt-3">
                        <span class="text-[10px] text-gray-500">Compared to Savings (3.5%)</span>
                        <span class="text-xs font-bold text-green-400 fd-extra-amt" data-val="0">+₹0</span>
                    </div>
                </div>
                
                <button class="w-full py-2.5 rounded-xl text-sm font-semibold transition-all btn-3d
                    @(isBest ? "bg-green-500 hover:bg-green-400 text-dark" : "bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 border border-blue-500/20")">
                    Open Fixed Deposit
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const amountInput = document.getElementById('amountInput');
            const amountSlider = document.getElementById('amountSlider');
            const savingsRate = 3.5;
            let calculateTimeout;
            
            async function fetchCalculations(amount) {
                // Show loading state
                document.querySelectorAll('#banksGrid > div').forEach(card => {
                    card.querySelector('.fd-return-amt').innerHTML = '<i class="fas fa-spinner fa-spin text-gray-500"></i>';
                    card.querySelector('.fd-extra-amt').innerHTML = '<i class="fas fa-spinner fa-spin text-gray-500"></i>';
                });
                document.getElementById('extraEarnThisYear').innerHTML = '<i class="fas fa-spinner fa-spin text-gray-500 text-sm"></i>';

                try {
                    const response = await fetch('/Compare/Calculate', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ Amount: parseFloat(amount) })
                    });
                    
                    const result = await response.json();
                    
                    if (result.error) {
                        // Display error logic (simple alert or toast)
                        console.error(result.error);
                        document.querySelectorAll('#banksGrid > div').forEach(card => {
                            card.querySelector('.fd-return-amt').textContent = 'Error';
                            card.querySelector('.fd-extra-amt').textContent = '--';
                        });
                        document.getElementById('extraEarnThisYear').textContent = '--';
                        return;
                    }
                    
                    let maxExtra = 0;
                    
                    if (result.success && result.data) {
                        result.data.forEach(item => {
                            const card = document.getElementById('bank-card-' + item.policyId);
                            if (card) {
                                card.querySelector('.fd-return-amt').textContent = '₹' + item.maturityAmount.toLocaleString('en-IN', { maximumFractionDigits: 0 });
                                card.querySelector('.fd-extra-amt').textContent = '+₹' + item.extraEarnings.toLocaleString('en-IN', { maximumFractionDigits: 0 });
                                if (item.extraEarnings > maxExtra) maxExtra = item.extraEarnings;
                            }
                        });
                        
                        document.getElementById('extraEarnThisYear').textContent = maxExtra.toLocaleString('en-IN', { maximumFractionDigits: 0 });
                    }
                } catch(e) {
                    console.error("Calculation fetch failed", e);
                }
            }
            
            function scheduleCalculation(val) {
                if(calculateTimeout) clearTimeout(calculateTimeout);
                calculateTimeout = setTimeout(() => {
                    fetchCalculations(val);
                }, 300); // 300ms debounce
            }
            
            function syncValues(source, target) {
                let val = source.value;
                if(val > 1000000) val = 1000000;
                if(val < 1000 && source.id === 'amountSlider') val = 1000;
                
                target.value = val;
                scheduleCalculation(val);
            }
            
            amountInput.addEventListener('input', () => syncValues(amountInput, amountSlider));
            amountSlider.addEventListener('input', () => syncValues(amountSlider, amountInput));
            
            // Fire initial calculation
            fetchCalculations(amountInput.value);
        });
    </script>
}
