@using ViaYou.Models
@model ViaYou.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-12">
    <h1 class="text-6xl font-bold text-red-600 mb-4">Error</h1>
    <h2 class="text-2xl text-gray-600 mb-8">An error occurred while processing your request.</h2>

    @if (Model.ShowRequestId)
    {
        <p class="text-gray-500">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-8 p-4 bg-yellow-50 border border-yellow-200 rounded-lg max-w-md mx-auto">
        <h3 class="font-semibold text-yellow-800">Development Mode</h3>
        <p class="text-sm text-yellow-700 mt-2">
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p class="text-xs text-yellow-600 mt-2">
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
            It can result in displaying sensitive information from exceptions.
        </p>
    </div>

    <a href="/Dashboard" class="inline-block mt-8 bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700 transition">
        ← Back to Dashboard
    </a>
</div>