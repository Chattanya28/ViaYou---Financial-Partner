@using System.Security.Claims
@using ViaYou.Data
@inject ApplicationDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - ViaYou</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Custom Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        dark: '#0A0A0F',
                        'dark-card': '#111115',
                        'dark-border': '#1E1E2A',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                    boxShadow: {
                        'glow': '0 0 20px rgba(59, 130, 246, 0.15)',
                        'glow-lg': '0 0 30px rgba(59, 130, 246, 0.25)',
                        '3d': '0 20px 35px -10px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(59, 130, 246, 0.05)',
                        'hover-3d': '0 25px 40px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(59, 130, 246, 0.15)',
                    }
                }
            }
        }
    </script>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <style>
        * {
            font-family: 'Inter', system-ui, sans-serif;
        }
        
        body {
            background: #0A0A0F;
        }
        
        /* 3D Card Effect */
        .card-3d {
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            transform: translateY(0);
        }
        
        .card-3d:hover {
            transform: translateY(-6px);
            box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(59, 130, 246, 0.2);
        }
        
        /* 3D Button Effect */
        .btn-3d {
            transition: all 0.2s ease;
            transform: translateY(0);
        }
        
        .btn-3d:active {
            transform: translateY(2px);
        }
        
        /* Icon Hover */
        .icon-3d {
            transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }
        
        .icon-3d:hover {
            transform: translateY(-4px) scale(1.1);
        }
        
        /* Glass Navigation */
        .glass-nav {
            background: rgba(10, 10, 15, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(59, 130, 246, 0.1);
        }
        
        /* Transaction Item */
        .transaction-item {
            transition: all 0.25s ease;
            cursor: pointer;
        }
        
        .transaction-item:hover {
            background: rgba(59, 130, 246, 0.05);
            transform: translateX(5px);
        }
        
        /* Category Item */
        .category-item {
            transition: all 0.25s ease;
            cursor: pointer;
        }
        
        .category-item:hover {
            background: rgba(59, 130, 246, 0.05);
            transform: scale(1.02);
        }
        
        /* Progress Bar 3D */
        .progress-3d {
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.3), 0 1px 0 rgba(255,255,255,0.05);
        }
        
        /* Floating Animation */
        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-4px); }
        }
        
        .float-animation {
            animation: float 4s ease-in-out infinite;
        }
        
        /* Pulse Animation */
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }
        
        .pulse-animation {
            animation: pulse 2s ease-in-out infinite;
        }
        
        /* Fade In */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-up {
            animation: fadeInUp 0.5s ease-out forwards;
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #1E1E2A;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #3B82F6;
            border-radius: 10px;
        }
        
        canvas {
            max-height: 200px;
            width: 100%;
        }

        /* LIGHT THEME INVERSION ENGINE */
        .light-theme.bg-dark, .light-theme .bg-dark { background-color: #F8FAFC !important; }
        .light-theme .bg-dark-card { background-color: #FFFFFF !important; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05) !important; }
        .light-theme .border-dark-border { border-color: #E2E8F0 !important; }
        .light-theme .text-white { color: #0F172A !important; }
        .light-theme .text-gray-300, .light-theme .text-gray-400, .light-theme .text-gray-500 { color: #475569 !important; }
        .light-theme .bg-white\/5, .light-theme .bg-white\/10 { background-color: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.05) !important; }
        .light-theme .hover\:bg-white\/5:hover, .light-theme .hover\:bg-white\/10:hover { background-color: rgba(0,0,0,0.08) !important; }
        .light-theme .glass-nav { background: rgba(255, 255, 255, 0.95) !important; border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important; }
        .light-theme .card-3d:hover { box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(0, 0, 0, 0.05) !important; }
        .light-theme .progress-3d { background-color: #E2E8F0 !important; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1) !important; }
    </style>
</head>
<body class="bg-dark transition-colors duration-500 ease-in-out">
    @{
        var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    }
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Glass Navigation -->
        <nav class="glass-nav fixed top-0 left-0 right-0 z-50">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <a href="/Dashboard" class="flex items-center space-x-3 group">
                        <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg icon-3d">
                            <i class="fas fa-chart-line text-white text-sm"></i>
                        </div>
                        <span class="text-xl font-bold text-white tracking-tight">ViaYou</span>
                    </a>
                    
                    <div class="hidden md:flex items-center space-x-1">
                        <a href="/Dashboard" class="px-4 py-2 @(currentCtrl == "Dashboard" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-chart-pie text-xs"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/Transactions" class="px-4 py-2 @(currentCtrl == "Transactions" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-list-ul text-xs"></i>
                            <span>Ledger</span>
                        </a>
                        <a href="/Compare" class="px-4 py-2 @(currentCtrl == "Compare" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-arrow-trend-up text-xs"></i>
                            <span>Compare FD</span>
                        </a>
                        <a href="/Bills" class="px-4 py-2 @(currentCtrl == "Bills" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-file-invoice-dollar text-xs"></i>
                            <span>Bills</span>
                        </a>
                        <a href="/GoalSimulator" class="px-4 py-2 @(currentCtrl == "GoalSimulator" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-bullseye text-xs"></i>
                            <span>Goals</span>
                        </a>
                        <a href="/Tax" class="px-4 py-2 @(currentCtrl == "Tax" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-landmark text-xs"></i>
                            <span>Tax Base</span>
                        </a>
                        <a href="/Reports" class="px-4 py-2 @(currentCtrl == "Reports" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-chart-line text-xs"></i>
                            <span>Reports</span>
                        </a>
                        <a href="/Security" class="px-4 py-2 @(currentCtrl == "Security" ? "text-white bg-white/10" : "text-gray-300 hover:text-white hover:bg-white/10") rounded-xl transition flex items-center space-x-2 text-sm font-medium">
                            <i class="fas fa-shield-haltered text-xs"></i>
                            <span>Security</span>
                        </a>
                    </div>
                    
                    <div class="flex items-center space-x-4">
                        @{
                            int unreadCount = 0;
                            var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                            if (int.TryParse(userIdStr, out int uid))
                            {
                                unreadCount = DbContext.Notifications.Count(n => n.UserId == uid && !n.IsRead);
                            }
                        }
                        
                        <a href="/Notification" class="relative p-2 text-gray-400 hover:text-white transition group">
                            <i class="fas fa-bell text-lg group-hover:animate-bounce"></i>
                            @if (unreadCount > 0)
                            {
                                <span class="absolute top-1 right-1.5 flex h-2.5 w-2.5">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
                                </span>
                            }
                        </a>

                        <div class="relative group">
                            <button class="flex items-center space-x-3 bg-white/5 hover:bg-white/10 rounded-full px-3 py-1.5 transition-all border border-white/10">
                            <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center">
                                <span class="text-white text-sm font-semibold">
                                    @{
                                        var userName = User.Identity?.Name ?? "U";
                                        var initial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
                                    }
                                    @initial
                                </span>
                            </div>
                            <span class="text-gray-300 text-sm font-medium hidden sm:inline">
                                @{
                                    var displayName = User.Identity?.Name ?? "User";
                                    var namePart = displayName.Contains('@') ? displayName.Split('@')[0] : displayName;
                                }
                                @namePart
                            </span>
                            <i class="fas fa-chevron-down text-gray-500 text-xs"></i>
                        </button>
                        
                        <div class="absolute right-0 mt-2 w-56 bg-dark-card rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 border border-dark-border">
                            <div class="p-2">
                                <div class="px-3 py-3 border-b border-dark-border">
                                    <p class="text-sm font-semibold text-white">@namePart</p>
                                    <p class="text-xs text-gray-500 mt-0.5">@User.Identity?.Name</p>
                                </div>
                                <div class="py-1">
                                    <a href="/Profile" class="block px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition flex items-center space-x-2">
                                        <i class="fas fa-user-circle w-4 text-center"></i>
                                        <span>My Profile</span>
                                    </a>
                                </div>
                                <div class="border-t border-dark-border py-1">
                                    <button type="button" onclick="toggleThemeMode()" class="w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition flex items-center space-x-2">
                                        <i class="fas fa-adjust w-4 text-center"></i>
                                        <span id="themeToggleText">Light Mode</span>
                                    </button>
                                </div>
                                <div class="border-t border-dark-border py-1">
                                    <form id="logoutForm" asp-controller="Auth" asp-action="Logout" method="post" class="hidden"></form>
                                    <button type="button" onclick="openLogoutModal()" class="w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-red-500/10 transition flex items-center space-x-2">
                                        <i class="fas fa-sign-out-alt w-4 text-center"></i>
                                        <span>Sign Out</span>
                                    </button>
                                </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
        
        <main class="pt-20 pb-8 animate-fade-up relative">
            
            <!-- Global Toast Engine -->
            <div id="globalToastContainer" class="fixed top-20 right-4 z-[9999] flex flex-col gap-3 pointer-events-none">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="toast-popup pointer-events-auto p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center gap-4 shadow-xl backdrop-blur-md transform transition-all duration-500 slide-in">
                        <i class="fas fa-check-circle text-emerald-500 text-lg"></i>
                        <span class="text-emerald-400 font-medium text-sm">@TempData["SuccessMessage"]</span>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="toast-popup pointer-events-auto p-4 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-center gap-4 shadow-xl backdrop-blur-md transform transition-all duration-500 slide-in">
                        <i class="fas fa-triangle-exclamation text-rose-500 text-lg"></i>
                        <span class="text-rose-400 font-medium text-sm">@TempData["ErrorMessage"]</span>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
        
        <!-- Mobile Bottom Nav -->
        <div class="md:hidden fixed bottom-0 left-0 right-0 bg-dark-card/95 backdrop-blur-lg border-t border-dark-border z-50">
            <div class="flex justify-around py-2">
                <a href="/Dashboard" class="flex flex-col items-center py-2 px-4 @(currentCtrl == "Dashboard" ? "text-blue-500" : "text-gray-500 hover:text-blue-500 transition")">
                    <i class="fas fa-chart-pie text-xl"></i>
                    <span class="text-xs mt-1">Home</span>
                </a>
                <a href="/Compare" class="flex flex-col items-center py-2 px-3 @(currentCtrl == "Compare" ? "text-blue-500" : "text-gray-500 hover:text-blue-500 transition")">
                    <i class="fas fa-arrow-trend-up text-xl"></i>
                    <span class="text-xs mt-1">Compare</span>
                </a>
                <a href="/Reports" class="flex flex-col items-center py-2 px-3 @(currentCtrl == "Reports" ? "text-emerald-500" : "text-gray-500 hover:text-emerald-500 transition")">
                    <i class="fas fa-chart-line text-xl"></i>
                    <span class="text-xs mt-1">Reports</span>
                </a>
                <a href="/Bills" class="flex flex-col items-center py-2 px-3 @(currentCtrl == "Bills" ? "text-purple-500" : "text-gray-500 hover:text-purple-500 transition")">
                    <i class="fas fa-file-invoice-dollar text-xl"></i>
                    <span class="text-xs mt-1">Bills</span>
                </a>
                <a href="/Tax" class="flex flex-col items-center py-2 px-3 @(currentCtrl == "Tax" ? "text-blue-500" : "text-gray-500 hover:text-blue-500 transition")">
                    <i class="fas fa-landmark text-xl"></i>
                    <span class="text-xs mt-1">Tax Base</span>
                </a>
            </div>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }
    
    <!-- Logout Confirmation Modal -->
    <div id="logoutModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-dark/80 backdrop-blur-sm" onclick="closeLogoutModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-dark-card border border-dark-border rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4 transform scale-95 transition-transform duration-300" id="logoutModalContent">
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-triangle-exclamation text-red-500 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white">Sign Out?</h3>
                    <p class="text-sm text-gray-400 mt-1">Are you sure you want to end your session?</p>
                </div>
            </div>
            
            <div class="flex space-x-3">
                <button type="button" onclick="closeLogoutModal()" class="flex-1 px-4 py-2.5 rounded-xl border border-dark-border text-gray-300 hover:bg-white/5 hover:text-white transition font-medium text-sm">
                    Cancel
                </button>
                <button type="button" onclick="submitLogoutForm()" class="flex-1 px-4 py-2.5 rounded-xl bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-white shadow-[0_0_15px_rgba(225,29,72,0.3)] transition font-medium text-sm border border-red-500/50">
                    Sign Out
                </button>
            </div>
        </div>
    </div>
    
    <script>
        function openLogoutModal() {
            const modal = document.getElementById('logoutModal');
            const content = document.getElementById('logoutModalContent');
            modal.classList.remove('hidden');
            
            // Allow CSS transition to fire by pushing state change to next frame
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    modal.classList.remove('opacity-0');
                    modal.classList.add('opacity-100');
                    content.classList.remove('scale-95');
                    content.classList.add('scale-100');
                });
            });
            
            document.addEventListener('keydown', handleEscKey);
        }

        function closeLogoutModal() {
            const modal = document.getElementById('logoutModal');
            const content = document.getElementById('logoutModalContent');
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
            
            document.removeEventListener('keydown', handleEscKey);
        }

        function handleEscKey(e) {
            if (e.key === 'Escape') {
                closeLogoutModal();
            }
        }

        function submitLogoutForm() {
            document.getElementById('logoutForm').submit();
        }

        // --- Theme Engine Initialization ---
        function initTheme() {
            const isLight = localStorage.getItem('viayou-theme') === 'light';
            if (isLight) {
                document.body.classList.add('light-theme');
                const tText = document.getElementById('themeToggleText');
                if (tText) tText.innerText = 'Dark Mode';
            }
        }
        
        function toggleThemeMode() {
            const isLightActive = document.body.classList.contains('light-theme');
            const tText = document.getElementById('themeToggleText');
            
            if (isLightActive) {
                document.body.classList.remove('light-theme');
                localStorage.setItem('viayou-theme', 'dark');
                if (tText) tText.innerText = 'Light Mode';
            } else {
                document.body.classList.add('light-theme');
                localStorage.setItem('viayou-theme', 'light');
                if (tText) tText.innerText = 'Dark Mode';
            }
        }

        // --- Global Toast Manager ---
        function autoDismissToasts() {
            setTimeout(() => {
                const toasts = document.querySelectorAll('.toast-popup');
                toasts.forEach(el => {
                    el.style.opacity = '0';
                    el.style.transform = 'translateX(50px)';
                    setTimeout(() => el.remove(), 500);
                });
            }, 6000);
        }

        // Initialize systems on load
        document.addEventListener('DOMContentLoaded', () => {
            initTheme();
            autoDismissToasts();
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>